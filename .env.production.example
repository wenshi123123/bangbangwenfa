# ============================================
# 生产环境配置模板
# ============================================
# 使用方法：
# 1. 复制此文件为 .env.production
# 2. 填入真实的生产环境配置值
# 3. 切勿将 .env.production 提交到代码仓库

# ============================================
# Supabase 配置（必需）
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# JWT 密钥（必需）
# ============================================
# 用于签发和验证 JWT Token，必须使用高熵随机密钥
# 生成方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 或：openssl rand -hex 64
JWT_SECRET=generate_with_openssl_rand_-hex_64_or_crypto_randomBytes_64

# ============================================
# 微信支付配置（必需）
# ============================================
WEIXIN_APPID=your_weixin_appid_here
WEIXIN_MCHID=your_mchid_here
WEIXIN_SERIAL_NO=your_serial_no_here
WEIXIN_APIV3_KEY=your_apiv3_key_here

# 微信支付私钥（PEM 格式，保留换行符为 \n）
# 在扣子平台配置环境变量时，将私钥内容完整粘贴（包含 -----BEGIN----- 和 -----END-----）
WEIXIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere...\n-----END PRIVATE KEY-----

# 微信支付平台证书（PEM 格式，保留换行符为 \n）
WEIXIN_PLATFORM_CERT=-----BEGIN CERTIFICATE-----\nYourPlatformCertHere...\n-----END CERTIFICATE-----

# 微信支付回调 URL（替换为你的真实域名）
WEIXIN_CALLBACK_URL=https://your-domain.com/api/pay/callback

# ============================================
# 腾讯云短信配置（可选）
# ============================================
TENCENT_SECRET_ID=your_tencent_secret_id
TENCENT_SECRET_KEY=your_tencent_secret_key
TENCENT_SMS_APP_ID=your_sms_app_id
TENCENT_SMS_SIGN_NAME=your_sms_sign_name
TENCENT_SMS_TEMPLATE_ID=your_sms_template_id
TENCENT_SMS_ORDER_TEMPLATE_ID=your_order_template_id

# ============================================
# 内部服务密钥（必需）
# ============================================
# 用于内部服务间认证
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_KEY=your_internal_service_key_here

# ============================================
# 站点公开 URL（用于支付二维码、回调等）
# ============================================
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ============================================
# Sentry 错误监控（强烈推荐）
# ============================================
# 获取 DSN: Sentry → Settings → Projects → Client Keys (DSN)
# 不配置则 Sentry 自动禁用
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ============================================
# 微信公众号配置（可选）
# ============================================
# WEIXIN_OA_APPID=your_oa_appid
# WEIXIN_OA_APPSECRET=your_oa_appsecret
# WEIXIN_OA_TEMPLATE_ID=your_template_id

# ============================================
# 火山引擎短信（可选 — 备用短信通道）
# ============================================
# VOLCENGINE_ACCESS_KEY=your_volc_access_key
# VOLCENGINE_SECRET_KEY=your_volc_secret_key
# VOLCENGINE_SMS_ACCOUNT_ID=your_account_id
# VOLCENGINE_SMS_TEMPLATE_ID=your_template_id
# VOLCENGINE_SMS_SIGN=your_sign_name

# ============================================
# 环境配置
# ============================================
NODE_ENV=production
DEPLOY_ENV=PROD
